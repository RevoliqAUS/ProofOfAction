{
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "frontend/index.html"
    },
    {
      "source": "/api/proof-of-action",
      "destination": "src/main.py"
    },
    {
      "source": "/analyze",
      "destination": "src/main.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "src/main.py"
    }
  ]
}
